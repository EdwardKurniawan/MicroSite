  <!-- ═══════════════════════════════════════════════
       JSON-LD SCHEMA STACK
  ════════════════════════════════════════════════ -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "Article",
        "@id": "https://yourdomain.com/things-to-do/#article",
        "headline": "17 Best Things To Do in Kanazawa (2026 Japan Guide)",
        "description": "The definitive local guide to Kanazawa — Kenroku-en garden, Higashi Chaya geisha district, 21st Century Museum, samurai quarters, and hidden ninja temples.",
        "image": { "@type": "ImageObject", "url": "https://yourdomain.com/images/kanazawa-hero.jpg", "width": 1200, "height": 630 },
        "author": { "@type": "Person", "name": "Yuki Tanaka", "description": "Kanazawa-based travel writer and local expert", "url": "https://yourdomain.com/authors/yuki-tanaka/" },
        "publisher": { "@type": "Organization", "name": "Kanazawa Guide", "logo": { "@type": "ImageObject", "url": "https://yourdomain.com/logo.png" } },
        "datePublished": "2026-01-01",
        "dateModified": "2026-03-18",
        "mainEntityOfPage": "https://yourdomain.com/things-to-do/"
      },
      {
        "@type": "BreadcrumbList",
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://yourdomain.com/" },
          { "@type": "ListItem", "position": 2, "name": "Kanazawa", "item": "https://yourdomain.com/" },
          { "@type": "ListItem", "position": 3, "name": "Things To Do", "item": "https://yourdomain.com/things-to-do/" }
        ]
      },
      {
        "@type": "FAQPage",
        "mainEntity": [
          {
            "@type": "Question",
            "name": "What is Kanazawa best known for?",
            "acceptedAnswer": { "@type": "Answer", "text": "Kanazawa is best known for Kenroku-en (one of Japan's three great gardens), its preserved geisha districts (Higashi Chaya and Nishi Chaya), the samurai quarter of Nagamachi, the 21st Century Museum of Contemporary Art, and its exceptional seafood and Kaga cuisine. It's often called 'Little Kyoto' for its traditional culture, but unlike Kyoto it was never bombed and retains an authenticity that many visitors find more affecting." }
          },
          {
            "@type": "Question",
            "name": "How many days do you need in Kanazawa?",
            "acceptedAnswer": { "@type": "Answer", "text": "Two full days covers the essential Kanazawa — Kenroku-en, the castle, Higashi Chaya, Nagamachi, Omicho Market, and the 21st Century Museum. Three days lets you slow down, walk the Higashiyama temple trail, visit Myoryuji (the ninja temple), and take a half-day trip to Noto Peninsula or Shirakawa-go. Four days is ideal if you want to go deep into Kaga Onsen and the surrounding countryside." }
          },
          {
            "@type": "Question",
            "name": "What is the best time to visit Kanazawa?",
            "acceptedAnswer": { "@type": "Answer", "text": "April (cherry blossom in Kenroku-en), June–July (early summer before peak humidity), and October–November (autumn foliage at the garden and temple walks) are the best times. Winter brings heavy snow that transforms Kenroku-en into a landscape of yukitsuri (rope-supported trees) — one of Japan's most iconic seasonal sights. Avoid August if you dislike heat and humidity." }
          },
          {
            "@type": "Question",
            "name": "Do I need to book Kanazawa attractions in advance?",
            "acceptedAnswer": { "@type": "Answer", "text": "The one attraction requiring advance booking is Myoryuji (the Ninja Temple) — reservations are mandatory and fill up quickly on weekends. The 21st Century Museum is busiest on weekends; arriving at opening time (10am) avoids queues. All other major sights including Kenroku-en, Higashi Chaya, and Kanazawa Castle are walk-in." }
          },
          {
            "@type": "Question",
            "name": "How do you get to Kanazawa?",
            "acceptedAnswer": { "@type": "Answer", "text": "The fastest route from Tokyo is the Hokuriku Shinkansen (bullet train) — 2.5 hours from Tokyo Station to Kanazawa Station, around ¥14,000 one way. From Osaka or Kyoto, the limited express Thunderbird takes 2–2.5 hours (¥7,500). Kanazawa is not on the main Tokaido Shinkansen line, so it requires a deliberate detour — which is precisely why it's remained more authentic than Kyoto." }
          },
          {
            "@type": "Question",
            "name": "What food is Kanazawa famous for?",
            "acceptedAnswer": { "@type": "Answer", "text": "Kanazawa's food culture is built around fresh seafood from the Sea of Japan — particularly snow crab (November–March), yellowtail (buri), and Nodoguro (blackthroat seaperch). Kaga cuisine (Kaga ryori) is the local kaiseki tradition, more rustic than Kyoto's. Other specialities: jibu-ni (duck stew with fu dumplings), cold soba, gold-leaf ice cream, and wagashi (traditional sweets). Omicho Market is the place to eat it all." }
          },
          {
            "@type": "Question",
            "name": "Is a Japan Rail Pass worth it for Kanazawa?",
            "acceptedAnswer": { "@type": "Answer", "text": "Yes, if you're combining Kanazawa with Tokyo and/or Osaka on a longer Japan trip. The Hokuriku Shinkansen from Tokyo alone costs around ¥28,000 return, and a 7-day JR Pass costs ¥50,000 — so it pays off quickly if you're also covering other Shinkansen legs. From Kanazawa, day trips to Shirakawa-go (UNESCO village) are covered by the pass." }
          }
        ]
      }
    ]
  }
  </script>

