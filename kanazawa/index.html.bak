  <button class="scroll-top" id="scrollTop" aria-label="Scroll to top">↑</button>

  <script>
    // Scroll to top
    const scrollBtn = document.getElementById('scrollTop');
    window.addEventListener('scroll', () => scrollBtn.classList.toggle('visible', window.scrollY > 400));
    scrollBtn.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));

    // Mobile nav
    const hamburger = document.querySelector('.nav-hamburger');
    hamburger && hamburger.addEventListener('click', () => {
      const links = document.querySelector('.nav-links');
      if (links) {
        links.style.display = links.style.display === 'flex' ? 'none' : 'flex';
        links.style.flexDirection = 'column';
        links.style.position = 'absolute';
        links.style.top = '60px';
        links.style.left = '0';
        links.style.right = '0';
        links.style.background = '#fff';
        links.style.padding = '20px 24px';
        links.style.borderBottom = '1px solid #e5e3df';
        links.style.boxShadow = '0 4px 16px rgba(0,0,0,.10)';
      }
    });

    // Venues from DB
    (function () {
      let allVenues = [];
      let activeCategory = '';

      function renderVenues(venues) {
        const grid = document.getElementById('venues-grid');
        if (!venues.length) {
          grid.innerHTML = '<div style="grid-column:1/-1;text-align:center;padding:60px 0;color:var(--ink-muted);">No venues found.</div>';
          return;
        }
        grid.innerHTML = venues.map(v => `
          <div class="venue-card">
            ${v.image_url
              ? `<img class="venue-card-img" src="${v.image_url}" alt="${v.name}" loading="lazy" />`
              : `<div class="venue-card-img" style="display:flex;align-items:center;justify-content:center;font-size:2.5rem;background:#f8f7f5;">🏯</div>`
            }
            <div class="venue-card-body">
              <div class="venue-cat">${v.category || 'Attraction'}</div>
              <h3>${v.name}</h3>
              ${v.short_description ? `<p>${v.short_description}</p>` : ''}
              <div class="venue-meta">
                ${v.rating ? `<span class="venue-rating">★ ${v.rating}</span>` : ''}
                ${v.reviews ? `<span>${Number(v.reviews).toLocaleString()} reviews</span>` : ''}
                ${v.duration ? `<span>· ${v.duration}</span>` : ''}
              </div>
              ${v.opening_hours ? `<div style="font-size:.78rem;color:var(--ink-muted);margin-bottom:12px;">🕐 ${v.opening_hours}</div>` : ''}
              <a class="venue-cta" href="/${v.slug}/">Book / Details →</a>
            </div>
          </div>
        `).join('');
      }

      function buildFilters(venues) {
        const cats = [...new Set(venues.map(v => v.category).filter(Boolean))].sort();
        const bar = document.getElementById('venue-filters');
        cats.forEach(cat => {
          const btn = document.createElement('button');
          btn.className = 'vf-btn';
          btn.dataset.cat = cat;
          btn.textContent = cat;
          bar.appendChild(btn);
        });
      }

      function setActiveFilter(cat) {
        activeCategory = cat;
        document.querySelectorAll('.vf-btn').forEach(b => b.classList.toggle('vf-active', b.dataset.cat === cat));
        renderVenues(cat ? allVenues.filter(v => v.category === cat) : allVenues);
      }

      document.getElementById('venue-filters').addEventListener('click', e => {
        const btn = e.target.closest('.vf-btn');
        if (btn) setActiveFilter(btn.dataset.cat);
      });

      fetch('/api/venues')
        .then(r => r.json())
        .then(data => { allVenues = data; buildFilters(data); renderVenues(data); })
        .catch(() => {
          document.getElementById('venues-grid').innerHTML =
            '<div style="grid-column:1/-1;text-align:center;padding:60px 0;color:var(--ink-muted);">Could not load venues. Please try again.</div>';
        });
    })();
  </script>

</body>
</html>
