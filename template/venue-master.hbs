<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{seo.title}}</title>
  <meta name="description" content="{{seo.description}}" />
  <link rel="canonical" href="{{seo.canonical}}" />
  <meta property="og:type" content="article" />
  <meta property="og:title" content="{{seo.og.title}}" />
  <meta property="og:description" content="{{seo.og.description}}" />
  <meta property="og:image" content="{{seo.og.image}}" />
  <meta property="og:url" content="{{seo.canonical}}" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="{{seo.twitter.title}}" />
  <meta name="twitter:description" content="{{seo.twitter.description}}" />
  <meta name="twitter:image" content="{{seo.twitter.image}}" />
  <script type="application/ld+json">{{{json seo.schema}}}</script>

  <link rel="stylesheet" href="/shared/index.css" />
  <link rel="stylesheet" href="/shared/global-nav.css" />
  <script src="/shared/global-nav.js" defer></script>

  <style>
    :root {
      --theme-accent: {{theme.accent}};
      --theme-accent-dark: {{theme.accentDark}};
      --theme-accent-light: {{theme.accentLight}};
    }
  </style>
  <script>
    window.CITY_NAME = "{{city_name}}";
    window.CITY_SLUG = "{{city_slug}}";
    window.PAGE_CONTEXT = {{{json this}}};
  </script>
</head>
<body>
  <main class="page-shell">
    {{> venue-hero}}

    <section class="section-shell">
      <div class="shell editorial-layout">
        <div class="editorial-stack">
          <article class="editorial-panel">
            <h2 class="section-title" style="font-size:clamp(1.8rem, 3vw, 2.8rem);">Why it matters</h2>
            <p class="page-subtitle-compact" style="margin-top:0.8rem;">{{venue.lead}}</p>
            <div class="copy-block" style="margin-top:1.2rem;">{{{venue.body_html}}}</div>
          </article>

          {{#if venue.booking_url}}
            <article class="editorial-panel">
              <span class="section-eyebrow">Booking</span>
              <h2 class="sidebar-title">Reserve this stop before you lock the day</h2>
              <p class="footer-copy">Use the tracked booking flow to compare pricing and avoid losing availability on popular dates.</p>
              <div class="editorial-actions">
                <a href="{{venue.booking_url}}" class="button-link">Check Availability</a>
                <a href="{{navigation.home_url}}#collections" class="button-link button-link-secondary">Compare More Options</a>
              </div>
            </article>
          {{/if}}
        </div>

        <aside class="editorial-stack">
          <article class="toolkit-card">
            <h3>Visit Snapshot</h3>
            <div class="transport-list">
              {{#if venue.category}}<div class="transport-item"><strong>Category</strong>: {{venue.category}}</div>{{/if}}
              {{#if venue.duration}}<div class="transport-item"><strong>Duration</strong>: {{venue.duration}}</div>{{/if}}
              {{#if venue.opening_hours}}<div class="transport-item"><strong>Opening hours</strong>: {{venue.opening_hours}}</div>{{/if}}
              {{#if venue.address}}<div class="transport-item"><strong>Address</strong>: {{venue.address}}</div>{{/if}}
            </div>
          </article>

          <article class="toolkit-card">
            <h3>Local Context</h3>
            <p>{{author.bio}}</p>
            {{#if venue.rating}}<div class="editorial-note"><strong>Rating</strong> {{venue.rating}} / 5 from {{venue.reviews}} reviews.</div>{{/if}}
          </article>
        </aside>
      </div>
    </section>

    {{> cta-band cta_band}}
  </main>

  {{> footer}}

  <script>
    document.addEventListener('DOMContentLoaded', function () {
      const els = document.querySelectorAll('.reveal');
      const io = new IntersectionObserver(function (entries) {
        entries.forEach(function (entry) {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
            io.unobserve(entry.target);
          }
        });
      }, { threshold: 0.1 });
      els.forEach(function (el) { io.observe(el); });
    });
  </script>
</body>
</html>
