<a href="{{url}}" class="story-card story-card-collection">
  <div class="story-visual">
    <img src="{{image}}" alt="{{alt}}" loading="lazy" />
    {{#if count}}<span class="story-badge">{{count}}</span>{{/if}}
  </div>
  <div class="story-body">
    <h3>{{title}}</h3>
    <p>{{description}}</p>
    <span class="story-link">{{cta}}</span>
  </div>
</a>
