<a href="{{url}}" class="story-card story-card-district">
  <div class="story-visual">
    <img src="{{image}}" alt="{{alt}}" loading="lazy" />
  </div>
  <div class="story-body">
    <h3>{{name}}</h3>
    {{#if tagline}}<p>{{tagline}}</p>{{/if}}
    <span class="story-link">Explore District</span>
  </div>
</a>
