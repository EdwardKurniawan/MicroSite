<footer class="site-footer">
  <div class="shell">
    <div class="footer-grid">
      <div class="footer-col">
        <a href="{{navigation.home_url}}" class="footer-brand-mark">{{footer.brand_name}}<span> Insider</span></a>
        <p class="footer-copy">{{footer.description}}</p>
      </div>

      <div class="footer-col">
        <h4>Explore</h4>
        <div class="footer-links">
          {{#each footer.local_links}}
            <a href="{{url}}">{{title}}</a>
          {{/each}}
        </div>
      </div>

      <div class="footer-col">
        <h4>About</h4>
        <div class="footer-links">
          {{#each footer.about_links}}
            <a href="{{url}}">{{title}}</a>
          {{/each}}
        </div>
        <h4 style="margin-top:1.3rem;">Network</h4>
        <div class="footer-links">
          {{#each footer.network_links}}
            <a href="{{url}}" target="_blank" rel="noreferrer">{{name}}</a>
          {{/each}}
        </div>
      </div>

      <div class="footer-col">
        <h4>{{footer.newsletter.title}}</h4>
        <p class="footer-copy">{{footer.newsletter.description}}</p>
        <form id="newsletter-form" class="newsletter-form">
          <input
            type="email"
            id="newsletter-email"
            class="newsletter-input"
            placeholder="{{footer.newsletter.placeholder}}"
            required
          />
          <button type="submit" class="button-link">{{footer.newsletter.button_label}}</button>
          <div id="newsletter-status" class="footer-copy" hidden></div>
        </form>
      </div>
    </div>

    <div class="footer-bottom">
      <span>© {{current_year}} {{footer.brand_name}}. City-first guidance, built for smarter booking.</span>
      <span>{{footer.legal}}</span>
    </div>
  </div>

  <script>
    (function () {
      const form = document.getElementById('newsletter-form');
      const emailInput = document.getElementById('newsletter-email');
      const statusEl = document.getElementById('newsletter-status');
      if (!form || !statusEl || !emailInput) return;

      form.addEventListener('submit', async (event) => {
        event.preventDefault();
        statusEl.hidden = false;
        statusEl.textContent = 'Sending...';

        try {
          const response = await fetch('/api/newsletter', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ email: emailInput.value, city_slug: '{{city_slug}}' })
          });
          const result = await response.json();
          if (!response.ok) {
            throw new Error(result.error || 'Signup failed');
          }
          emailInput.value = '';
          statusEl.textContent = 'You are in. Check your inbox soon.';
        } catch (error) {
          statusEl.textContent = error.message || 'Something went wrong. Please try again.';
        }
      });
    })();
  </script>
</footer>
