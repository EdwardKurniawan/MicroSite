<section class="page-hero page-hero-guide" style="background-image:url('{{hero.image}}')">
  <div class="page-hero-overlay"></div>
  <div class="page-hero-content shell">
    <span class="page-kicker">{{hero.eyebrow}}</span>
    <h1 class="page-title">{{hero.title}}</h1>
    {{#if hero.tagline}}<p class="page-subtitle">{{hero.tagline}}</p>{{/if}}
    <div class="planner-shell" id="plan-your-trip">
      <label class="planner-label" for="hero-search-input">AI Planner</label>
      <div class="planner-row">
        <input type="text" id="hero-search-input" placeholder="Where should I start in {{city_name}}?" class="planner-input" />
        <button id="hero-search-button" class="planner-button">Explore</button>
      </div>
    </div>
  </div>
</section>
