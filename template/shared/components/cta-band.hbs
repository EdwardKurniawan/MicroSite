<section class="cta-band">
  <div class="shell shell-narrow">
    <span class="section-eyebrow">{{eyebrow}}</span>
    <h2 class="cta-title">{{title}}</h2>
    <p class="cta-copy">{{description}}</p>
    <div class="cta-actions">
      <a href="{{primary.url}}" class="button-link">{{primary.label}}</a>
      <a href="{{secondary.url}}" class="button-link button-link-secondary">{{secondary.label}}</a>
    </div>
  </div>
</section>
