<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{seo.title}}</title>
  <meta name="description" content="{{seo.description}}" />
  <link rel="canonical" href="{{seo.canonical}}" />
  <meta property="og:type" content="article" />
  <meta property="og:title" content="{{seo.og.title}}" />
  <meta property="og:description" content="{{seo.og.description}}" />
  <meta property="og:image" content="{{seo.og.image}}" />
  <meta property="og:url" content="{{seo.canonical}}" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="{{seo.twitter.title}}" />
  <meta name="twitter:description" content="{{seo.twitter.description}}" />
  <meta name="twitter:image" content="{{seo.twitter.image}}" />
  <script type="application/ld+json">{{{json seo.schema}}}</script>

  <link rel="stylesheet" href="/shared/index.css" />
  <link rel="stylesheet" href="/shared/global-nav.css" />
  <script src="/shared/global-nav.js" defer></script>

  <style>
    :root {
      --theme-accent: {{theme.accent}};
      --theme-accent-dark: {{theme.accentDark}};
      --theme-accent-light: {{theme.accentLight}};
    }
  </style>
  <script>
    window.CITY_NAME = "{{city_name}}";
    window.CITY_SLUG = "{{city_slug}}";
    window.PAGE_CONTEXT = {{{json this}}};
  </script>
</head>
<body>
  <main class="page-shell">
    {{> subpage-hero}}

    <section class="section-shell">
      <div class="shell editorial-layout">
        <div class="editorial-stack">
          <div>
            {{> section-heading eyebrow="Overview" title=hero.title description=hero.tagline}}
            <div class="copy-block">{{{intro.body_html}}}</div>
          </div>

          {{#if todos.length}}
            <div>
              {{> section-heading eyebrow="What To Do" title="Build the right version of this page" description="These are the stops and experiences that define this collection."}}
              <div class="editorial-stack">
                {{#each todos}}
                  <article class="editorial-panel">
                    <span class="editorial-kicker">{{num}}</span>
                    <h3 class="sidebar-title" style="margin-top:0.5rem;">{{title}}</h3>
                    <p>{{description}}</p>
                  </article>
                {{/each}}
              </div>
            </div>
          {{/if}}

          {{#if attractions.length}}
            <div id="top-attractions">
              {{> section-heading eyebrow="Top Stops" title="Featured attractions and booking signals"}}
              <div class="editorial-stack">
                {{#each attractions}}
                  {{> attraction-card}}
                {{/each}}
              </div>
            </div>
          {{/if}}

          {{#if products.length}}
            <div>
              {{> section-heading eyebrow="Tickets & Tours" title="Useful bookings to compare"}}
              <div class="story-grid">
                {{#each products}}
                  <a href="{{link}}" class="story-card">
                    {{#if image_url}}
                      <div class="story-visual"><img src="{{image_url}}" alt="{{title}}" loading="lazy" /></div>
                    {{/if}}
                    <div class="story-body">
                      {{#if category}}<span class="editorial-kicker">{{category}}</span>{{/if}}
                      <h3>{{title}}</h3>
                      <p>{{description}}</p>
                      <span class="story-link">{{cta}}</span>
                    </div>
                  </a>
                {{/each}}
              </div>
            </div>
          {{/if}}

          {{#if foods.length}}
            <div>
              {{> section-heading eyebrow="Eat & Drink" title="Places that match the mood of the page"}}
              <div class="food-list">
                {{#each foods}}
                  <article class="food-card">
                    {{#if tag}}<span class="food-tag">{{tag}}</span>{{/if}}
                    <h3 class="sidebar-title">{{title}}</h3>
                    <p>{{description}}</p>
                  </article>
                {{/each}}
              </div>
            </div>
          {{/if}}
        </div>

        <aside class="editorial-stack">
          {{#if facts.length}}
            <article class="toolkit-card">
              <h3>Quick Facts</h3>
              {{> fact-grid items=facts}}
            </article>
          {{/if}}

          {{#if getting_there.length}}
            <article class="toolkit-card">
              <h3>Getting There</h3>
              <div class="transport-list">
                {{#each getting_there}}
                  <div class="transport-item">{{#if icon}}<strong>{{icon}}</strong> {{/if}}{{text}}</div>
                {{/each}}
              </div>
            </article>
          {{/if}}

          <article class="toolkit-card">
            <h3>Written By</h3>
            <p>{{author.bio}}</p>
            <a href="{{author.url}}" class="story-link">Meet {{author.name}}</a>
          </article>
        </aside>
      </div>
    </section>

    {{#if faqs.length}}
      <section id="faqs" class="section-shell section-shell-muted">
        <div class="shell shell-narrow">
          {{> section-heading eyebrow="FAQs" title="What people ask before adding this to the itinerary"}}
          {{> faq-list items=faqs}}
        </div>
      </section>
    {{/if}}

    {{> cta-band cta_band}}
  </main>

  {{> footer}}

  <script>
    document.addEventListener('DOMContentLoaded', function () {
      const els = document.querySelectorAll('.reveal');
      const io = new IntersectionObserver(function (entries) {
        entries.forEach(function (entry) {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
            io.unobserve(entry.target);
          }
        });
      }, { threshold: 0.1 });
      els.forEach(function (el) { io.observe(el); });
    });
  </script>
</body>
</html>
