<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{seo.title}}</title>
  <meta name="description" content="{{seo.description}}" />
  <link rel="canonical" href="{{seo.canonical}}" />
  <meta property="og:type" content="website" />
  <meta property="og:title" content="{{seo.og.title}}" />
  <meta property="og:description" content="{{seo.og.description}}" />
  <meta property="og:image" content="{{seo.og.image}}" />
  <meta property="og:url" content="{{seo.canonical}}" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="{{seo.twitter.title}}" />
  <meta name="twitter:description" content="{{seo.twitter.description}}" />
  <meta name="twitter:image" content="{{seo.twitter.image}}" />
  <script type="application/ld+json">{{{json seo.schema}}}</script>

  <link rel="stylesheet" href="/shared/index.css" />
  <link rel="stylesheet" href="/shared/global-nav.css" />
  <script src="/shared/global-nav.js" defer></script>
  <script src="/shared/ai-search.js" defer></script>

  <style>
    :root {
      --theme-accent: {{theme.accent}};
      --theme-accent-dark: {{theme.accentDark}};
      --theme-accent-light: {{theme.accentLight}};
    }
  </style>
  <script>
    window.CITY_NAME = "{{city_name}}";
    window.CITY_SLUG = "{{city_slug}}";
    window.PAGE_CONTEXT = {{{json this}}};
  </script>
</head>
<body>
  <main class="page-shell">
    {{> guide-hero}}

    <section id="city-overview" class="section-shell">
      <div class="shell insight-grid">
        <div>
          {{> section-heading eyebrow=intro.eyebrow title=intro.title description=seo.description}}
          <div class="copy-block">{{{intro.body_html}}}</div>
        </div>
        <aside class="insight-aside">
          <h3 class="sidebar-title">Essential Briefing</h3>
          {{> fact-grid items=quick_info}}
        </aside>
      </div>
    </section>

    {{#if planning_highlights.length}}
      <section class="section-shell section-shell-muted">
        <div class="shell">
          {{> section-heading eyebrow="How To Use This Guide" title="Decisions that change the trip most" description="The fastest way to make Amsterdam feel easier is to book the right things early, choose the right base, and leave room for the city between the big-ticket stops."}}
          <div class="playbook-grid">
            {{#each planning_highlights}}
              <article class="playbook-card">
                <span class="editorial-kicker">{{kicker}}</span>
                <h3>{{title}}</h3>
                <p>{{description}}</p>
                {{#if url}}
                  <a href="{{url}}" class="story-link">{{link_label}}</a>
                {{/if}}
              </article>
            {{/each}}
          </div>
        </div>
      </section>
    {{/if}}

    <section id="collections" class="section-shell section-shell-muted">
      <div class="shell">
        {{> section-heading eyebrow="Collections" title="Choose your angle on the city" description=category_intro}}
        <div class="story-grid">
          {{#each categories}}
            {{> category-card}}
          {{/each}}
        </div>
      </div>
    </section>

    <section id="neighbourhoods" class="section-shell">
      <div class="shell">
        {{> section-heading eyebrow="Neighbourhoods" title="Decode the districts before you book" description="Each district has its own pace, crowd profile, and best moment in the day. Use the neighbourhood pages to decide where {{city_name}} feels most like your trip."}}
        <div class="story-grid">
          {{#each neighbourhoods}}
            {{> district-card}}
          {{/each}}
        </div>
      </div>
    </section>

    {{#if itinerary.days.length}}
      <section id="plan-your-trip" class="section-shell section-shell-muted">
        <div class="shell">
          {{> section-heading eyebrow="Itinerary" title=itinerary.title description=itinerary.intro}}
          <div class="itinerary-grid">
            {{#each itinerary.days}}
              <article class="itinerary-card">
                <h3 class="itinerary-day">{{day}}</h3>
                {{#each items}}
                  <div class="itinerary-slot">
                    <div class="slot-time">{{time}}</div>
                    <div class="slot-copy">
                      <strong>{{title}}</strong>
                      <span>{{description}}</span>
                    </div>
                  </div>
                {{/each}}
              </article>
            {{/each}}
          </div>
          {{#if itinerary.tip_html}}
            <div class="editorial-note" style="margin-top:1.5rem;">
              <strong>{{itinerary.tip_label}}</strong> {{{itinerary.tip_html}}}
            </div>
          {{/if}}
        </div>
      </section>
    {{/if}}

    {{#if transport.items.length}}
      <section id="getting-around" class="section-shell">
        <div class="shell toolkit-grid">
          <article class="toolkit-card">
            <h3>Getting Around</h3>
            <div class="transport-list">
              {{#each transport.items}}
                <div class="transport-item"><strong>{{label}}</strong>{{#if value}}: {{value}}{{else}}{{#if text}} {{text}}{{/if}}{{/if}}</div>
              {{/each}}
            </div>
          </article>
          <article class="toolkit-card">
            <h3>Before You Go</h3>
            <p>{{transport.intro}}</p>
            {{#if transport.tip_html}}
              <div class="editorial-note"><strong>{{transport.tip_label}}</strong> {{{transport.tip_html}}}</div>
            {{/if}}
          </article>
        </div>
      </section>
    {{/if}}

    {{#if faqs.length}}
      <section id="faqs" class="section-shell section-shell-muted">
        <div class="shell shell-narrow">
          {{> section-heading eyebrow="FAQs" title="Questions travelers ask before they arrive"}}
          {{> faq-list items=faqs}}
        </div>
      </section>
    {{/if}}

    {{> cta-band cta_band}}
  </main>

  {{> footer}}

  <script>
    document.addEventListener('DOMContentLoaded', function () {
      const els = document.querySelectorAll('.reveal');
      const io = new IntersectionObserver(function (entries) {
        entries.forEach(function (entry) {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
            io.unobserve(entry.target);
          }
        });
      }, { threshold: 0.1 });
      els.forEach(function (el) { io.observe(el); });
    });
  </script>
</body>
</html>
